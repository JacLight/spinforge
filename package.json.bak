{
  "name": "spinforge",
  "version": "0.1.0",
  "description": "Open-source platform for on-demand execution of AI-generated applications",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel",
    "build": "lerna run build",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "clean": "lerna clean -y && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "lerna": "^8.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spinforge/spinforge.git"
  },
  "keywords": [
    "serverless",
    "runtime",
    "nodejs",
    "spinlet",
    "ai-apps"
  ],
  "author": "SpinForge Team",
  "license": "MIT"
}